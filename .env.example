# ============================================================
# DocLens Configuration
# Copy to .env and update values for production deployment
# ============================================================

# ============================================================
# Server Configuration
# ============================================================
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
DEMO_MODE=true
MAX_FILE_SIZE_MB=20

# ============================================================
# Security (CRITICAL: Change in production!)
# ============================================================
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32
DEBUG=false

# ============================================================
# Database
# ============================================================
DATABASE_URL=postgresql+asyncpg://doclens:doclens_pass@localhost:5432/doclens
DATABASE_URL_SYNC=postgresql://doclens:doclens_pass@localhost:5432/doclens

# ============================================================
# Redis (caching, rate limiting, task queue)
# ============================================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ============================================================
# Storage (S3/MinIO)
# ============================================================
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=doclens-documents

# ============================================================
# OCR Configuration
# ============================================================
OCR_USE_GPU=false
OCR_MAX_IMAGE_SIZE=4096
OCR_MAX_FILE_SIZE=20971520

# Confidence thresholds for auto-fill and review
CONFIDENCE_AUTO_FILL=0.95
CONFIDENCE_REVIEW=0.70

# ============================================================
# External APIs (optional - for validation)
# ============================================================
FMS_CHECK_ENABLED=false
FNS_CHECK_ENABLED=false
DADATA_API_KEY=
DADATA_SECRET=

# ============================================================
# Monitoring & Logging
# ============================================================
SENTRY_DSN=
PROMETHEUS_ENABLED=false
